            )

            # ── Выбор количества сцен ──────────────────────────────────
            with gr.Row():
                seq_count_dd = gr.Dropdown(
                    label   = "🔢 Количество сцен (ключевых кадров)",
                    choices = [1, 2, 3, 4, 5],
                    value   = 5,
                    scale   = 1,
                )
